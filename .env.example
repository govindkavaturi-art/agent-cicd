# GitHub tokens
DEPLOY_TOKEN=ghp_xxxxxxxxxxxx          # Your main account PAT (repo, workflow scopes)
BOT_GITHUB_TOKEN=ghp_xxxxxxxxxxxx     # Bot account PAT (repo scope)

# CueAPI
CUEAPI_API_KEY=cue_xxxxxxxxxxxx       # From cueapi.ai dashboard or self-hosted instance

# Resend (email notifications)
RESEND_API_KEY=re_xxxxxxxxxxxx        # From resend.com dashboard

# Your app
HEALTH_ENDPOINT_URL=https://staging.yourapp.com/health
